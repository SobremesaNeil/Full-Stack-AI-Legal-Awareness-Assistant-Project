DATABASE_URL=postgresql+pg8000://postgres:postgres@localhost:5432/chatbot
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Mock Mode ──────────────────────────────────────────────────────────────────
# Set USE_MOCK=true to run the project without a real database or AI API key.
# In mock mode:
#   • A local SQLite file (mock.db) is used instead of PostgreSQL.
#   • AI responses are pre-defined strings – no OpenAI key is required.
#   • The ChromaDB / RAG knowledge base is skipped.
# This is ideal for local development, UI prototyping, and CI environments.
#
# USE_MOCK=true
 