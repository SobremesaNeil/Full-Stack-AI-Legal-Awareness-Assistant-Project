# ============================================================
# Mock environment – run the backend without any external services
#
# Usage:
#   cp .env.mock .env
#   pip install -r requirements.txt
#   uvicorn main:app --reload
#
# This configuration uses:
#   • SQLite instead of PostgreSQL  (no database server needed)
#   • MOCK_AI=true                  (canned AI responses, no OpenAI key needed)
# ============================================================

# SQLite async database (file created automatically on first run)
DATABASE_URL=sqlite+aiosqlite:///./chatbot_mock.db

# Disable real AI calls – return canned legal responses instead
MOCK_AI=true

# Default admin password (must satisfy: ≥8 chars, upper+lower+digit)
ADMIN_DEFAULT_PASSWORD=Admin123

# Allowed frontend origins (adjust if your dev server uses a different port)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
